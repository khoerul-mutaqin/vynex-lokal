<odoo>
    <data>
        <record id="view_mrp_production_form_inherit" model="ir.ui.view">
            <field name="name">vyn.mrp.production.form.inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='miscellaneous']/group/group[2]/field[@name='company_id']" position="after">
                    <field name="vyn_customer_order_number" string="Customer Order Number"/>
                </xpath>
                <xpath expr="//field[@name='move_raw_ids']/list[1]/field[@name='product_id']" position="after">
                    <field name="vyn_stock" string="Stock" optional="show"/>
                </xpath>
                <xpath expr="//page[@name='miscellaneous']/group[1]/group[2]/field[@name='origin']" position="after">
                    <field name="vyn_contained_qty_in_pack_1" string="Contained Qty in Pack 1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
