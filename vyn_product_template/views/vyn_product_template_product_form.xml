<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Ajout de champs personnalisés dans la vue formulaire du produit -->
        <record id="view_product_template_product_form_inherit" model="ir.ui.view">
            <field name="name">vyn.product.template.product.form.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='uom_po_id']" position="after">
                    <field name="vyn_marque" string="Brand"/>
                    <field name="vyn_uc_per_unit" string="uc per unit"/>
                    <field name="vyn_unit_per_inner" string="unit per inner"/>
                </xpath>
                <xpath expr="//form[@name='Product Template']/sheet[@name='product_form']/notebook[1]/page[@name='general_information']/group[1]/group[@name='group_standard_price']/field[@name='company_id']" position="after">
                    <field name="vyn_ancien_code" string="Old code"/>
                    <field name="vyn_packing_type" string="Packing type"/>
                </xpath>
                <xpath expr="//field[@name='seller_ids']" position="inside">
                    <list string="Vendor Information" multi_edit="1" editable="bottom">
                        <field name="sequence" widget="handle" attrs="{}" invisible="0"/>
                        <field name="display_name" readonly="0"/>
                        <field name="price" string="Price"/>
                        <field name="product_uom" groups="uom.group_uom"/>
                        <field name="currency_id" groups="base.group_multi_currency"/>
                        <field name="product_id" readonly="0" optional="hide" invisible="context.get('product_template_invisible_variant', False)" groups="product.group_product_variant" domain="[('product_tmpl_id', '=?', context.get('default_product_tmpl_id', False))]" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                        <field name="product_tmpl_id" string="Product" readonly="1" invisible="context.get('visible_product_tmpl_id', True)" optional="show"/>
                        <field name="product_name" optional="hide"/>
                        <field name="product_code" optional="hide"/>
                        <field name="date_start" optional="hide"/>
                        <field name="date_end" optional="hide"/>
                        <field name="company_id" readonly="0" groups="base.group_multi_company" optional="hide"/>
                        <field name="min_qty" optional="show"/>
                        <field name="write_uid" optional="hide"/>
                        <field name="write_date" optional="hide"/>
                        <field name="delay" optional="show"/>
                    </list>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
