<odoo>
    <data>
        <record id="vyn_sale_order_tree_inherit" model="ir.ui.view">
            <field name="name">vyn.sale.order.tree.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
            <field name="arch" type="xml">
                <xpath expr="//list[1]/field[@name='name']" position="before">
                    <xpath expr="//field[@name='fal_title']" position="move"/>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>
                <xpath expr="//field[@name='amount_total']" position="after">
                    <field name="margin_percent" optional="show" widget="percentage" avg="Average of Margin (%)"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
