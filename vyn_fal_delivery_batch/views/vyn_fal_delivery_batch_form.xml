<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Ajout de champs personnalisés dans la vue formulaire des lignes de mouvement de stock -->
        <record id="view_fal_delivery_batch_form_inherit" model="ir.ui.view">
            <field name="name">vyn.fal.delivery.batch.form.inherit</field>
            <field name="model">fal.journal.entry.group</field>
            <field name="inherit_id" ref="fal_delivery_batch.view_fal_journal_entry_group_form_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='batch_line_ids']" position="inside">
                    <list string="Invoice Line" editable="bottom" create="0">
                        <field name="to_print"/>
                        <field optional="show" name="vyn_customer_order" string="Customer order"/>
                        <field name="batch_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="invoice_line_id" invisible="1"/>
                        <field name="product_id" invisible="1"/>
                        <field name="name" readonly="1"/>
                        <field name="quantity" readonly="1"/>
                        <field name="balanced_quantity"/>
                        <field name="product_uom_id" readonly="1"/>
                        <field name="fapiao_currency_id" invisible="1"/>
                        <field name="fapiao_price_unit" widget="monetary" options="{'currency_field': 'fapiao_currency_id'}"/>
                        <field name="fapiao_subtotal_vat" widget="monetary" options="{'currency_field': 'fapiao_currency_id'}"/>
                        <field name="price_unit" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="1"/>
                        <field name="subtotal_vat" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="1"/>
                        <field name="box_line_ids" widget="many2many_tags" invisible="1"/>
                    </list>
                </xpath>
                <xpath expr="//field[@name='box_line_ids']" position="inside">
                    <list string="Delivery Box Line" create="0">
                        <field name="batch_id" invisible="1"/>
                        <field name="batch_line_id" invisible="1"/>
                        <field name="box_number"/>
                        <field name="box_type"/>
                        <field name="box_length"/>
                        <field name="box_width"/>
                        <field name="box_height"/>
                        <field name="product_id"/>
                        <field name="name"/>
                        <field name="quantity"/>
                        <field name="product_uom_id"/>
                        <field name="product_weight"/>
                        <field name="n_weight"/>
                        <field name="g_weight"/>
                    </list>
                    <list string="Delivery Box Line" create="0">
                        <field name="batch_id" invisible="1"/>
                        <field name="batch_line_id" invisible="1"/>
                        <field name="box_number"/>
                        <field name="box_type"/>
                        <field name="box_length"/>
                        <field name="box_width"/>
                        <field name="box_height"/>
                        <field name="product_id"/>
                        <field name="name"/>
                        <field name="quantity"/>
                        <field name="product_uom_id"/>
                        <field name="product_weight"/>
                        <field name="n_weight"/>
                        <field name="g_weight"/>
                    </list>
                    <list string="Delivery Box Line" create="0">
                        <field name="batch_id" invisible="1"/>
                        <field name="batch_line_id" invisible="1"/>
                        <field name="box_number"/>
                        <field name="box_type"/>
                        <field name="box_length"/>
                        <field name="box_width"/>
                        <field name="box_height"/>
                        <field name="product_id"/>
                        <field name="name"/>
                        <field name="quantity"/>
                        <field name="product_uom_id"/>
                        <field name="product_weight"/>
                        <field name="n_weight"/>
                        <field name="g_weight"/>
                    </list>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
