<odoo>
    <data>
        <!-- Ajout de champs personnalisés dans la vue formulaire du stock picking -->
        <record id="view_stock_picking_form_inherit" model="ir.ui.view">
            <field name="name">vyn.stock.picking.form.inherit</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="vyn_product_to_produce"/>
                    <field name="vyn_quantity_to_produce"/>
                    <field name="vyn_customer_order_number"/>
                </xpath>
                <xpath expr="//field[@name='move_ids_without_package']" position="attributes">
                    <attribute name="readonly">state == 'done' and is_locked == True</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='operations']/field[@name='move_ids_without_package']/list[1]/field[@name='product_id']" position="after">
                    <field optional="show" name="vyn_source_qty" string="Source Qty"/>
                </xpath>
                <xpath expr="//field[@name='product_packaging_id']" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='operations']/field[@name='move_ids_without_package']/list[1]/field[@name='quantity']" position="attributes">
                    <attribute name="sum">Sum of Done</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
