<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_stock_picking_batch_form_inherit" model="ir.ui.view">
            <field name="name">vyn.stock.picking.batch.form.inherit</field>
            <field name="model">stock.picking.batch</field>
            <field name="inherit_id" ref="stock_picking_batch.stock_picking_batch_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='move_line_ids']" position="inside">
                    <list editable="top" decoration-muted="state == 'cancel'" string="Move Lines" default_order="location_id">
                        <field name="tracking" invisible="1"/>
                        <field name="state" invisible="1"/>
                        <field name="product_id" context="{'default_detailed_type': 'product'}" required="1" attrs="{'readonly': [('id', '!=', False)]}"/>
                        <field name="vyn_customer_order_number" string="Customer Order Number" optional="show"/>
                        <field name="picking_id" required="1" attrs="{'readonly': [('id', '!=', False)]}" options="{'no_create_edit': True}" domain="[('id', 'in', parent.picking_ids)]" optional="hide"/>
                        <field name="lot_id" groups="stock.group_production_lot" attrs="{'readonly': [('tracking', 'not in', ['lot', 'serial'])]}"/>
                        <field name="location_id" optional="hide"/>
                        <field name="location_dest_id" optional="hide"/>
                        <field name="package_id" groups="stock.group_tracking_lot" optional="hide"/>
                        <field name="result_package_id" groups="stock.group_tracking_lot" optional="hide"/>
                        <field name="quantity_product_uom" readonly="1" sum="Sum of Réservé"/>
                        <field name="product_uom_id" options="{'no_create': True}" groups="uom.group_uom" readonly="1" force_save="1"/>
                        <field name="qty_done" sum="Sum of Fait"/>
                        <field name="company_id" groups="base.group_multi_company" force_save="1" optional="hide"/>
                    </list>
                </xpath>
                <xpath expr="//field[@name='picking_ids']" position="inside">
                    <list>
                        <field name="name"/>
                        <field name="scheduled_date"/>
                        <field name="location_id"/>
                        <field name="backorder_id"/>
                        <field name="origin"/>
                        <field name="state"/>
                    </list>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
