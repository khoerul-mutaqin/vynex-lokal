<odoo>
    <data>
        <record id="vyn_purchase_order_tree_inherit" model="ir.ui.view">
            <field name="name">vyn.purchase.order.tree.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <xpath expr="//field[@name='origin']" position="move"/>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>
                <xpath expr="//field[@name='activity_ids']" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>
                <xpath expr="//field[@name='amount_total']" position="after">
                    <xpath expr="//field[@name='date_approve']" position="move"/>
                </xpath>
                <xpath expr="//field[@name='invoice_status']" position="attributes">
                    <attribute name="optional">show</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
