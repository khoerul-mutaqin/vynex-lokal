<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="vyn_account_move_form_inherit" model="ir.ui.view">
            <field name="name">vyn.account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='invoice_line_ids']/list[1]" position="attributes">
                    <attribute name="default_order">product_id asc</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='invoice_line_ids']/list[1]/field[@name='account_line_title']" position="attributes">
                    <attribute name="attrs">{}</attribute>
                    <attribute name="optional">hide</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='invoice_line_ids']/list[1]/field[@name='account_id']" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='invoice_line_ids']/list[1]/field[@name='quantity']" position="attributes">
                    <attribute name="sum">Sum of Quantity</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[2]/field[@name='line_ids']/list[1]/field[@name='account_id']" position="before">
                    <field name="product_id" optional="show"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
